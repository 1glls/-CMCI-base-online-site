// Schema Prisma pour CMCI Belgique
generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Admin {
  id        String   @id @default(uuid())
  email     String   @unique
  password  String
  name      String
  role      String   @default("admin")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("admins")
}

model Event {
  id                      String   @id @default(uuid())
  title                   String
  date                    String
  time                    String
  location                String
  description             String
  image                   String?
  registrationUrl         String?  // URL vers Google Form (optionnel)
  registrationButtonText  String?  // Texte personnalisé du bouton d'inscription
  exploreButtonText       String?  // Texte personnalisé du bouton explorer
  exploreUrl              String?  // URL personnalisée du bouton explorer
  status                  String   @default("published") // published, draft
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt

  @@map("events")
}

model Testimonial {
  id        String   @id @default(uuid())
  name      String
  role      String
  quote     String
  image     String?
  status    String   @default("published") // published, draft
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("testimonials")
}

model GalleryImage {
  id        String   @id @default(uuid())
  src       String
  alt       String
  category  String
  status    String   @default("published") // published, draft
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@map("gallery_images")
}

model SocialMediaPost {
  id             String   @id @default(uuid())
  platform       String   // youtube, facebook, instagram, tiktok, snapchat
  postId         String   @unique
  content        String?
  mediaUrl       String?
  thumbnailUrl   String?
  author         String?
  publishedAt    DateTime?
  status         String   @default("pending") // pending, approved, rejected
  validatedBy    String?
  validatedAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("social_media_posts")
}

model Settings {
  id    String @id @default(uuid())
  key   String @unique
  value String

  @@map("settings")
}

model HeroSlide {
  id          String   @id @default(uuid())
  title       String
  subtitle    String
  image       String?
  imageMobile String?  // Version mobile optimisée de l'image
  eventId     String?  // Lien optionnel vers un événement
  buttonText  String?  // Texte du bouton (optionnel, ex: "S'inscrire", "En savoir plus")
  buttonUrl   String?  // URL du bouton (Google Form, page externe, etc.)
  order       Int      @default(0)
  status      String   @default("published") // published, draft
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("hero_slides")
}

model Newsletter {
  id          String   @id @default(uuid())
  email       String   @unique
  status      String   @default("active") // active, unsubscribed
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("newsletter_subscribers")
}

model Assembly {
  id          String   @id @default(uuid())
  city        String
  address     String
  latitude    Float?
  longitude   Float?
  schedule    String
  phone       String
  email       String
  status      String   @default("published") // published, draft
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("assemblies")
}

model Ministry {
  id          String   @id @default(uuid())
  title       String
  description String
  icon        String?  // Nom de l'icône ou URL
  image       String?
  order       Int      @default(0)
  status      String   @default("published") // published, draft
  link        String?  // Lien vers page dédiée ou contact
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("ministries")
}

model Form {
  id             String   @id @default(uuid())
  title          String
  description    String?
  slug           String   @unique  // URL-friendly identifier
  fields         String   // JSON array of form fields
  googleSheetId  String?  // Google Spreadsheet ID
  googleSheetUrl String?  // Full URL for admin reference
  status         String   @default("published") // published, draft, closed
  submitCount    Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  submissions    FormSubmission[]

  @@map("forms")
}

model FormSubmission {
  id        String   @id @default(uuid())
  formId    String
  data      String   // JSON object of field values
  createdAt DateTime @default(now())

  form      Form     @relation(fields: [formId], references: [id], onDelete: Cascade)

  @@map("form_submissions")
}

// ---------------------------------------------------------------------------
// Traduction assistee du contenu de la base
// ---------------------------------------------------------------------------

/// Un compte de service de traduction (DeepL, etc.).
/// Plusieurs comptes peuvent coexister : quand le quota de l'un est epuise,
/// le suivant prend le relais par ordre de priorite.
model TranslationProvider {
  id             String   @id @default(uuid())
  name           String                        // libelle libre, ex. "DeepL principal"
  service        String   @default("deepl")    // deepl | libretranslate | mymemory
  apiKey         String                        // jamais renvoyee en entier par l'API
  characterLimit Int      @default(500000)
  charactersUsed Int      @default(0)          // cumul local, complete par /v2/usage
  remoteUsed     Int?                          // dernier releve cote fournisseur
  remoteLimit    Int?
  lastCheckedAt  DateTime?
  active         Boolean  @default(true)
  exhausted      Boolean  @default(false)      // pose sur erreur 456 (quota depasse)
  priority       Int      @default(0)          // le plus petit est essaye en premier
  lastError      String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@map("translation_providers")
}

/// Traduction d'un champ d'un enregistrement, dans une langue donnee.
/// Table generique : evite d'ajouter des colonnes a chaque modele traduisible.
model ContentTranslation {
  id        String   @id @default(uuid())
  model     String                        // Event | Ministry | Assembly | Testimonial | HeroSlide
  recordId  String
  language  String                        // en | nl
  field     String                        // title | description | ...
  value     String
  reviewed  Boolean  @default(false)      // corrige par un humain
  auto      Boolean  @default(true)       // issu d'une traduction automatique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([model, recordId, language, field])
  @@index([model, recordId, language])
  @@map("content_translations")
}

// ---------------------------------------------------------------------------
// Section « Livre & litterature »
// ---------------------------------------------------------------------------

model Book {
  id           String   @id @default(uuid())
  title        String
  author       String?
  description  String
  cover        String?  // /uploads/books/covers/...
  file         String?  // /uploads/books/files/...   PDF complet
  preview      String?  // extrait PDF optionnel
  externalLink String?
  order        Int      @default(0)
  status       String   @default("published")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  @@map("books")
}

model Tract {
  id          String         @id @default(uuid())
  slug        String         @unique   // "recevoir-jesus" — cible du QR-code
  title       String
  description String
  cover       String?
  order       Int            @default(0)
  status      String         @default("published")
  versions    TractVersion[]
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  @@map("tracts")
}

/// Une version linguistique d'un tract.
/// `reviewed` conditionne la publication : une traduction non relue par un
/// locuteur natif reste invisible, quel que soit son statut.
model TractVersion {
  id        String   @id @default(uuid())
  tractId   String
  tract     Tract    @relation(fields: [tractId], references: [id], onDelete: Cascade)
  language  String                       // ISO 639-1/3
  label     String                       // nom natif : "Kiswahili", "العربية"
  dir       String   @default("ltr")
  title     String
  file      String?                      // PDF
  previews  String?                      // JSON: ["/uploads/tracts/previews/...png"]
  reviewed  Boolean  @default(false)
  status    String   @default("draft")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tractId, language])
  @@map("tract_versions")
}
